{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,   // <--- needed for named import from JS
    "allowJs": true,           // <--- allows importing JS files
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true
  },
  "include": ["./**/*"],
  "exclude": ["node_modules"]
}