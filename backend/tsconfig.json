{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,

    "noEmit": true,

    "ignoreDeprecations": "6.0",

    "baseUrl": ".",
    "rootDir": "..",

    "typeRoots": ["./src/types", "./node_modules/@types"],  // ← add this

    "paths": {
      "@shared/*": ["../shared/*"]
    },
  },

  "include": [
    "src/**/*",
    "../shared/**/*"
  ],

  "exclude": ["node_modules"]
}