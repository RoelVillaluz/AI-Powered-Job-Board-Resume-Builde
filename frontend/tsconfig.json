{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    },

    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "../shared"]
}